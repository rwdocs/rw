{
  "name": "@rwdocs/core",
  "version": "0.1.10",
  "repository": {
    "type": "git",
    "url": "https://github.com/rwdocs/rw"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "core",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl"
    ]
  },
  "scripts": {
    "build": "napi build --manifest-path ../../crates/rw-napi/Cargo.toml --platform --release --js index.js --dts index.d.ts --output-dir .",
    "build:debug": "napi build --manifest-path ../../crates/rw-napi/Cargo.toml --platform --js index.js --dts index.d.ts --output-dir .",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
