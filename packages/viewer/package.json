{
  "name": "@rwdocs/viewer",
  "version": "0.1.24",
  "repository": {
    "type": "git",
    "url": "https://github.com/rwdocs/rw"
  },
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "prepublishOnly": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "npm run build && npm run build:lib && playwright test",
    "test:e2e:ui": "npm run build && npm run build:lib && playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-eslint-parser": "^1.6.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.11",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "exports": {
    ".": {
      "import": "./dist/lib/embed.js",
      "types": "./dist/lib/embed.d.ts"
    },
    "./embed.css": "./dist/lib/embed.css"
  },
  "files": [
    "dist/lib/",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@types/diff-match-patch": "^1.0.36",
    "diff-match-patch": "^1.0.5"
  }
}
