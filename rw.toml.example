# RW Configuration
# Copy this file to rw.toml and customize for your project.

# Server settings for the documentation server
[server]
host = "127.0.0.1"      # Host to bind to (default: 127.0.0.1)
port = 7979             # Port to bind to (default: 7979)

# Documentation settings
[docs]
source_dir = "docs"     # Directory containing markdown files (default: docs)
cache_enabled = true    # Enable/disable caching (default: true)

# Diagram rendering via Kroki
[diagrams]
kroki_url = "https://kroki.io"     # Kroki server URL (required for diagram rendering)
include_dirs = ["."]               # Directories to search for !include files
dpi = 192                          # DPI for diagram rendering (default: 192 for retina)

# Live reload for development (enabled by default)
[live_reload]
enabled = true          # Enable/disable live reload
