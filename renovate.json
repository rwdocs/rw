{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "ignorePaths": [
    ".github/workflows/release.yml"
  ],
  "labels": ["dependencies"],
  "minimumReleaseAge": "14 days",
  "postUpdateOptions": [
    "npmDedupe"
  ],
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "matchPackageNames": ["napi", "napi-build", "napi-derive"],
      "groupName": "napi-rs crates"
    }
  ]
}
